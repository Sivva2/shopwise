# ============================================
# ShopWise - .gitignore
# ============================================

# ===================
# Backend (Java/Maven)
# ===================
backend/target/
backend/*.jar
backend/*.war
backend/*.class
backend/.mvn/
backend/mvnw
backend/mvnw.cmd

# IDE
.idea/
*.iml
*.iws
.project
.classpath
.settings/
*.swp
*.swo

# ===================
# Frontend (Angular/Node)
# ===================
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.npm/
frontend/coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===================
# Environment
# ===================
.env
.env.local
.env.*.local
*.env

# ===================
# OS Files
# ===================
.DS_Store
Thumbs.db
*.tmp
*.temp

# ===================
# Docker
# ===================
*.pid
*.seed
*.pid.lock

# ===================
# Coverage Reports
# ===================
coverage/
*.lcov
.nyc_output/

# ===================
# Build outputs
# ===================
build/
out/
bin/

# ===================
# Temporary files
# ===================
tmp/
temp/
*.bak
*.backup
